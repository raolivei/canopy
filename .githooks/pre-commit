#!/bin/bash
# Pre-commit hook to enforce VERSION and CHANGELOG updates for content changes

set -e

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Paths that trigger VERSION requirement
CONTENT_PATHS=(
    "src/"
    "static/"
    "Dockerfile"
    "package.json"
    "package-lock.json"
    "svelte.config.js"
    "vite.config.ts"
)

# Paths that are exempt from VERSION requirement
EXEMPT_PATHS=(
    ".github/"
    "README.md"
    "LICENSE"
    ".gitignore"
    ".eslintrc"
    "tsconfig.json"
)

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Check if any content paths are modified
CONTENT_MODIFIED=false
for file in $STAGED_FILES; do
    # Skip exempt paths
    is_exempt=false
    for exempt in "${EXEMPT_PATHS[@]}"; do
        if [[ "$file" == "$exempt"* ]]; then
            is_exempt=true
            break
        fi
    done

    if [ "$is_exempt" = true ]; then
        continue
    fi

    # Check if file is in content paths
    for path in "${CONTENT_PATHS[@]}"; do
        if [[ "$file" == "$path"* ]]; then
            CONTENT_MODIFIED=true
            break 2
        fi
    done
done

# If no content modified, allow commit
if [ "$CONTENT_MODIFIED" = false ]; then
    exit 0
fi

# Content was modified - check VERSION and CHANGELOG
VERSION_MODIFIED=false
CHANGELOG_MODIFIED=false

for file in $STAGED_FILES; do
    if [ "$file" = "VERSION" ]; then
        VERSION_MODIFIED=true
    fi
    if [ "$file" = "CHANGELOG.md" ]; then
        CHANGELOG_MODIFIED=true
    fi
done

# Check if VERSION was bumped
if [ "$VERSION_MODIFIED" = false ]; then
    echo -e "${RED}ERROR: Content changes detected but VERSION file not updated${NC}"
    echo ""
    echo "Modified content files:"
    for file in $STAGED_FILES; do
        for path in "${CONTENT_PATHS[@]}"; do
            if [[ "$file" == "$path"* ]]; then
                echo "  - $file"
                break
            fi
        done
    done
    echo ""
    echo -e "${YELLOW}Required actions:${NC}"
    echo "1. Update VERSION file (e.g., 0.2.3 → 0.2.4)"
    echo "2. Update CHANGELOG.md with your changes"
    echo "3. Stage the changes: git add VERSION CHANGELOG.md"
    echo "4. Retry commit"
    echo ""
    echo "Why? FluxCD only deploys on new semantic version tags."
    exit 1
fi

# Check if CHANGELOG was updated
if [ "$CHANGELOG_MODIFIED" = false ]; then
    echo -e "${RED}ERROR: VERSION bumped but CHANGELOG.md not updated${NC}"
    echo ""
    echo -e "${YELLOW}Required actions:${NC}"
    echo "1. Update CHANGELOG.md with your changes"
    echo "2. Stage the changes: git add CHANGELOG.md"
    echo "3. Retry commit"
    exit 1
fi

# Verify VERSION format (semantic versioning)
VERSION=$(cat VERSION)
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo -e "${RED}ERROR: VERSION file has invalid format${NC}"
    echo "Current: $VERSION"
    echo "Expected: MAJOR.MINOR.PATCH (e.g., 0.2.4)"
    exit 1
fi

# All checks passed
echo -e "${GREEN}✓ VERSION and CHANGELOG updated${NC}"
exit 0
