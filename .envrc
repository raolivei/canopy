# ============================================
# CANOPY ENVIRONMENT
# ============================================
# Load parent workspace config first
source_up

# Auto-detect and activate Python virtual environment
# Supports: venv, .venv, env, or project-name/bin

if [[ -d "venv/bin" ]]; then
    source venv/bin/activate
elif [[ -d ".venv/bin" ]]; then
    source .venv/bin/activate
elif [[ -d "env/bin" ]]; then
    source env/bin/activate
elif [[ -d "${PWD##*/}/bin" ]]; then
    # Project name as venv (like swimTO/bin/activate)
    source "${PWD##*/}/bin/activate"
fi

# Project-specific variables
export PROJECT_NAME="$(basename $PWD)"
export PROJECT_ROOT="${PWD}"
export PYTHONPATH="${PWD}/backend"

echo "🚀 ${PROJECT_NAME} environment activated"

# AI Assistant
export ASSISTANT_PROVIDER=ollama
export OLLAMA_HOST=http://localhost:11434
export OLLAMA_MODEL=llama3.1:8b
# export OPENCLAW_URL=http://openclaw.eldertree.local:8080/v1
# export OPENCLAW_MODEL=llama3.1:70b
